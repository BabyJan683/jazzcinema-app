<?xml version="1.0" encoding="utf-8"?>
<!-- Netflix-style download card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp" android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#141414"
    app:cardCornerRadius="6dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- ── POSTER ─────────────────────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="90dp" android:layout_height="120dp">

            <ImageView android:id="@+id/img_thumb"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#1F1F1F"/>

            <!-- Red play icon overlay on poster -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="▶" android:textSize="28sp"
                android:textColor="#80E50914"/>
        </FrameLayout>

        <!-- ── INFO ──────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Title -->
            <TextView android:id="@+id/txt_title"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="15sp"
                android:textStyle="bold" android:fontFamily="sans-serif-medium"
                android:maxLines="2" android:ellipsize="end"/>

            <!-- Category -->
            <TextView android:id="@+id/txt_category"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#A3A3A3" android:textSize="12sp"
                android:layout_marginTop="3dp"/>

            <!-- Saved label -->
            <TextView android:id="@+id/txt_size"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#00B4D8" android:textSize="12sp"
                android:layout_marginTop="3dp"/>

            <!-- Download speed (shown during active download) -->
            <TextView android:id="@+id/txt_speed"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#F57C00" android:textSize="11sp"
                android:layout_marginTop="2dp" android:visibility="gone"/>

            <!-- Download progress bar -->
            <ProgressBar android:id="@+id/progress_download"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent" android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:progressTint="#E50914"
                android:progressBackgroundTint="#2A2A2A"
                android:max="100" android:visibility="gone"/>

            <!-- STREAM + Resume buttons -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="10dp">

                <Button android:id="@+id/btn_play"
                    android:layout_width="wrap_content" android:layout_height="34dp"
                    android:text="▶  STREAM"
                    android:textColor="#FFFFFF" android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="#E50914"
                    android:paddingHorizontal="14dp"
                    android:layout_marginEnd="8dp"/>

                <Button android:id="@+id/btn_resume"
                    android:layout_width="wrap_content" android:layout_height="34dp"
                    android:text="⟳  Resume"
                    android:textColor="#FFFFFF" android:textSize="12sp"
                    android:backgroundTint="#00B4D8"
                    android:paddingHorizontal="14dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── DELETE ICON — top right ────────────────────────────────────── -->
        <ImageButton android:id="@+id/btn_delete"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_gravity="top"
            android:layout_marginTop="4dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#6B6B6B"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
