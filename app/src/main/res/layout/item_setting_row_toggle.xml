<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="56dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="16dp" android:background="@color/bg_card">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/setting_name" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/white"
            android:textSize="14sp" android:text="Setting"/>
        <TextView android:id="@+id/setting_desc" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/text_muted"
            android:textSize="11sp" android:visibility="gone"/>
    </LinearLayout>
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/toggle_autoplay"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>
