<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:background="?attr/selectableItemBackground">

    <!-- Episode thumbnail -->
    <ImageView
        android:id="@+id/img_ep_thumb"
        android:layout_width="110dp"
        android:layout_height="68dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_movie_placeholder"
        android:background="#1A1A1A"/>

    <!-- Middle: EP chip + title + subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <!-- Bold title row: "Spider-Noir S01 E1" -->
        <TextView
            android:id="@+id/txt_ep_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- Subtitle: "Episode 1" in muted color -->
        <TextView
            android:id="@+id/txt_ep_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Episode 1"
            android:textColor="#00B4D8"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Download circle button (right) -->
    <ImageView
        android:id="@+id/btn_ep_play"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_download"
        android:background="@drawable/bg_circle_dark"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:contentDescription="Download"/>

</LinearLayout>
