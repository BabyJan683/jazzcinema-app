<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="64dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="16dp" android:background="#16161F">
    <TextView android:id="@+id/txt_rank"
        android:layout_width="32dp" android:layout_height="wrap_content"
        android:textColor="#E50914" android:textSize="20sp" android:textStyle="bold"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
        <TextView android:id="@+id/txt_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/txt_cat"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="12sp"/>
    </LinearLayout>
</LinearLayout>
