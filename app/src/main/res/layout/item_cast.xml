<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="80dp" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="center" android:layout_marginEnd="12dp">
    <ImageView android:id="@+id/img_cast_photo"
        android:layout_width="60dp" android:layout_height="60dp" android:scaleType="centerCrop" android:background="#222"/>
    <TextView android:id="@+id/txt_cast_name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="center"
        android:maxLines="2" android:ellipsize="end" android:layout_marginTop="4dp"/>
    <TextView android:id="@+id/txt_cast_role"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#888888" android:textSize="10sp" android:gravity="center" android:maxLines="1" android:ellipsize="end"/>
</LinearLayout>
